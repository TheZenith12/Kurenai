# ──────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/anime_platform?schema=public"

# ──────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ──────────────────────────────────────────
# JWT
# ──────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────
# APP
# ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ──────────────────────────────────────────
# QPAY
# ──────────────────────────────────────────
QPAY_BASE_URL=https://merchant.qpay.mn/v2
QPAY_USERNAME=your_qpay_merchant_username
QPAY_PASSWORD=your_qpay_merchant_password
QPAY_INVOICE_CODE=your_invoice_code

# ──────────────────────────────────────────
# BANK (Банкны шилжүүлэг хүлээн авах данс)
# ──────────────────────────────────────────
BANK_NAME=Khan Bank
BANK_ACCOUNT_NAME=Таны нэр
BANK_ACCOUNT_NO=5000XXXXXXXX

# ──────────────────────────────────────────
# CDN / STORAGE
# ──────────────────────────────────────────
CDN_URL=https://cdn.your-domain.com
S3_BUCKET=anime-platform-assets
S3_REGION=ap-northeast-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ──────────────────────────────────────────
# SEASON CONFIG
# ──────────────────────────────────────────
SEASON_START_DAY=1         # Даваа (0=Ням, 1=Даваа)
SEASON_END_DAY=5           # Баасан
SEASON_START_HOUR=0
SEASON_END_HOUR=23

# ──────────────────────────────────────────
# ENERGY CONFIG
# ──────────────────────────────────────────
ENERGY_REFILL_RATE=10      # per 30 minutes
ENERGY_MAX=100

# ──────────────────────────────────────────
# MODERATION
# ──────────────────────────────────────────
WARN_THRESHOLD=3
MUTE_DURATION_HOURS=1
AUTO_BAN_DURATION_HOURS=24

# ──────────────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
CHAT_RATE_LIMIT_MAX=30     # per minute per user
